{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set for Nerva windows",
  "windows": ["main", "sticky-*"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:webview:default",
    "core:webview:allow-create-webview-window",
    "core:event:default",
    "core:app:default",
    "core:path:default",
    "global-shortcut:default",
    "notification:default",
    "os:default"
  ]
}
